<%@ page import="java.sql.*" %><%@ page import="com.itserviceflow.utils.DBConnection" %><% try { Connection conn = DBConnection.getConnection(); PreparedStatement ps = conn.prepareStatement("SELECT ticket_id, ticket_number, title FROM ticket WHERE ticket_type = 'INCIDENT'"); ResultSet rs = ps.executeQuery(); while(rs.next()) { out.print("ID: " + rs.getInt("ticket_id") + ", NUM: " + rs.getString("ticket_number") + ", TITLE: " + rs.getString("title") + "<br>"); } } catch(Exception e) { out.print(e.getMessage()); } %>
